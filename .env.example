APP_NAME=IKB-Agent
ENVIRONMENT=local
STORE_BACKEND=json
DATA_DIR=./data
MAX_CHUNK_CHARS=1200
MIN_CHUNK_CHARS=260
ITEM_NAME_CHUNK_K=3
ITEM_NAME_CONTEXT_CHARS=2400
SEARCH_TOP_K=5

# MinerU
MINERU_MODEL_SOURCE=modelscope

# Qwen / DashScope OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_MODEL=qwen-flash
ITEM_MODEL=qwen-flash
VL_MODEL=qwen3-vl-flash

# Local mode keeps this false. Set true after configuring OPENAI_API_KEY.
ENABLE_EXTERNAL_LLM=false

# Embedding / reranker
EMBEDDING_MODEL=local-hash
EMBEDDING_DIM=1024
BGE_M3_PATH=
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cpu
BGE_FP16=false
BGE_RERANKER_LARGE=BAAI/bge-reranker-large
BGE_RERANKER_DEVICE=cpu
BGE_RERANKER_FP16=false

# Milvus
MILVUS_URL=http://localhost:19530
CHUNKS_COLLECTION=ikb_chunks
ITEM_NAME_COLLECTION=ikb_item_names
MILVUS_METRIC_TYPE=COSINE
MILVUS_MIN_COSINE_SCORE=0.2

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=ikb_agent

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ikb-agent
MINIO_SECURE=false

# MCP / DashScope tools
MCP_DASHSCOPE_BASE_URL=
